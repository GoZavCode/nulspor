# Port serveren koerer paa
PORT=3000

# --- Nulspor Deling ---
MAX_FILE_SIZE_MB=2048
DEFAULT_EXPIRY_DAYS=7
MAX_EXPIRY_DAYS=30
UPLOAD_DIR=./uploads
LOG_FILE=./data/upload-log.jsonl

# --- Database (deles af Deling, Paste og Mail) ---
DB_FILE=./data/nulspor.db

# --- Nulspor Mail ---
# Domaenet skal have MX-records pegende paa denne server for at kunne
# modtage rigtig mail fra internettet.
MAIL_DOMAIN=nulspor.dk
SMTP_PORT=25
SMTP_ENABLED=true
MAX_MAIL_SIZE_MB=10
MAX_INBOX_MESSAGES=50
